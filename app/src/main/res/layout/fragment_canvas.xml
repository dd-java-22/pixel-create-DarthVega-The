<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <!-- 1/8 screen height guideline -->
  <androidx.constraintlayout.widget.Guideline
    android:id="@+id/topGuide"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    app:layout_constraintGuide_percent="0.125" />

  <!-- Top toolbar (now moved down) -->
  <LinearLayout
    android:id="@+id/topBar"
    android:layout_width="0dp"
    android:layout_height="48dp"
    android:orientation="horizontal"
    android:background="#222"
    app:layout_constraintTop_toBottomOf="@id/topGuide"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <!-- toolbar buttons unchanged -->
    <ImageButton
      android:id="@+id/undoButton"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:background="@android:color/transparent"
      android:src="@drawable/ic_undo"
      app:tint="#fff"/>

    <ImageButton
      android:id="@+id/redoButton"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:background="@android:color/transparent"
      android:src="@drawable/ic_redo"
      app:tint="#fff"/>

    <View
      android:layout_width="1dp"
      android:layout_height="match_parent"
      android:layout_marginVertical="8dp"
      android:background="#444"/>

    <ImageButton
      android:id="@+id/pencilButton"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:background="@android:color/transparent"
      android:src="@drawable/ic_pencil"
      app:tint="#fff"/>

    <ImageButton
      android:id="@+id/eraserButton"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:background="@android:color/transparent"
      android:src="@drawable/ic_eraser"
      app:tint="#fff"/>

    <ImageButton
      android:id="@+id/fillBucketButton"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:background="@android:color/transparent"
      android:src="@drawable/ic_fill_bucket"
      app:tint="#fff"/>

    <ImageButton
      android:id="@+id/eyedropperButton"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:background="@android:color/transparent"
      android:src="@drawable/ic_eyedropper"
      app:tint="#fff"/>



    <View
      android:layout_width="1dp"
      android:layout_height="match_parent"
      android:layout_marginVertical="8dp"
      android:background="#444"/>

    <ImageButton
      android:id="@+id/resetZoomButton"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:background="@android:color/transparent"
      android:src="@drawable/ic_reset_zoom"
      app:tint="#fff"/>

    <ImageButton
      android:id="@+id/exportButton"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:background="@android:color/transparent"
      android:src="@drawable/ic_export"
      app:tint="#fff"/>

  </LinearLayout>

  <!-- Main content area -->
  <LinearLayout
    android:id="@+id/mainContent"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:orientation="horizontal"
    android:weightSum="1"
    app:layout_constraintTop_toBottomOf="@id/topBar"
    app:layout_constraintBottom_toTopOf="@id/bottomPanel"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <!-- Color palette -->
    <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/colorPalette"
      android:layout_width="64dp"
      android:layout_height="match_parent"
      android:background="#111"/>

    <!-- Canvas -->
    <edu.cnm.deepdive.pixelcreate.PixelCanvasView
      android:id="@+id/pixelCanvas"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:background="#000"/>
  </LinearLayout>


  <!-- Bottom panel with save/load and layers -->
  <LinearLayout
    android:id="@+id/bottomPanel"
    android:layout_width="0dp"
    android:layout_height="120dp"
    android:orientation="horizontal"
    android:background="#222"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <!-- Save/Load buttons on the left -->
    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:gravity="center"
      android:padding="8dp">

      <ImageButton
        android:id="@+id/saveButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_save"
        android:background="@android:color/transparent"
        android:scaleType="fitCenter"
        app:tint="#fff"
        android:contentDescription="Save"/>

      <ImageButton
        android:id="@+id/loadButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_load"
        android:background="@android:color/transparent"
        android:scaleType="fitCenter"
        app:tint="#fff"
        android:contentDescription="Load"/>

    </LinearLayout>

    <!-- Layer panel on the right -->
    <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/layerList"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:background="#222"/>

  </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
